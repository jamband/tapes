    "@types/node": "24.12.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.2",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "svelte": "5.54.0",
    "svelte-check": "4.4.5",
    "the-new-css-reset": "1.11.3",
    "typescript": "5.9.3",
