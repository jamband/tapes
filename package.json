    "@types/node": "24.12.4",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.18.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.0.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "svelte": "5.55.10",
    "svelte-check": "4.4.8",
    "the-new-css-reset": "1.11.3",
    "typescript": "6.0.3",
